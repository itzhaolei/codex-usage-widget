<Window x:Class="QuotaBubble.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="330" SizeToContent="Height" MinHeight="234"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
        Background="Transparent" ShowInTaskbar="True" Title="Quota Bubble"
        Icon="/Assets/icon.png">
  <Window.Resources>
    <Style x:Key="ControlButton" TargetType="Button">
      <Setter Property="Background" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#DDE6EA"/><Setter Property="FontSize" Value="13"/>
      <Setter Property="Cursor" Value="Hand"/><Setter Property="Focusable" Value="False"/>
    </Style>
    <VisualBrush x:Key="DotBrush" TileMode="Tile" Viewport="0,0,3,3" ViewportUnits="Absolute">
      <VisualBrush.Visual><Ellipse Width="1.1" Height="1.1" Fill="#00F020"/></VisualBrush.Visual>
    </VisualBrush>
  </Window.Resources>
  <Border x:Name="Root" CornerRadius="12" Background="#EB111D18" BorderBrush="#596A6F70" BorderThickness="1" Padding="12">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="32"/><RowDefinition Height="66"/><RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/><RowDefinition Height="38"/><RowDefinition Height="16"/>
      </Grid.RowDefinitions>

      <Grid Grid.Row="0">
        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
        <DockPanel Grid.Column="0" LastChildFill="False" Margin="0,0,8,0" VerticalAlignment="Center">
          <Border x:Name="PlanBadge" DockPanel.Dock="Right" CornerRadius="2" Margin="7,0,0,0" Padding="6,1" Height="16" VerticalAlignment="Center" Visibility="Collapsed">
            <TextBlock x:Name="PlanText" FontSize="10" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
          </Border>
          <TextBlock x:Name="TitleText" FontSize="15" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
        </DockPanel>
        <Border x:Name="Capsule" Grid.Column="1" Width="111" Height="28" CornerRadius="14" BorderBrush="#587282" BorderThickness="1" Background="#263D4A">
          <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
            <Button x:Name="ThemeButton" Grid.Column="0" Content="☀" Style="{StaticResource ControlButton}" ToolTip="Theme"/>
            <Border Grid.Column="1" HorizontalAlignment="Left" Width="1" Height="16" Background="#557A858B"/>
            <Button x:Name="PinButton" Grid.Column="1" Content="●" Style="{StaticResource ControlButton}" ToolTip="Pin"/>
            <Border Grid.Column="2" HorizontalAlignment="Left" Width="1" Height="16" Background="#557A858B"/>
            <Button x:Name="CloseButton" Grid.Column="2" Content="×" Style="{StaticResource ControlButton}" FontSize="16" ToolTip="Close"/>
          </Grid>
        </Border>
      </Grid>

      <Grid Grid.Row="1" Margin="0,8,0,0">
        <StackPanel Orientation="Horizontal">
          <TextBlock x:Name="WeekText" FontSize="13" FontWeight="Bold" Foreground="White"/>
          <TextBlock Text=" | " FontSize="10" Foreground="#AEB9BF"/>
          <TextBlock x:Name="ResetText" FontSize="10" Foreground="#AEB9BF" TextTrimming="CharacterEllipsis" MaxWidth="238"/>
        </StackPanel>
        <Grid Margin="0,23,0,0" Width="231" Height="35" HorizontalAlignment="Left" ClipToBounds="True">
          <Rectangle x:Name="ProgressPattern" Fill="{StaticResource DotBrush}" Opacity="0.78"/>
          <Rectangle x:Name="ProgressFill" Width="0" HorizontalAlignment="Left" Fill="#00F020"/>
          <Canvas IsHitTestVisible="False">
            <Border Canvas.Left="46" Width="1" Height="35" Background="#71006510"/>
            <Border Canvas.Left="92" Width="1" Height="35" Background="#71006510"/>
            <Border Canvas.Left="138" Width="1" Height="35" Background="#71006510"/>
            <Border Canvas.Left="184" Width="1" Height="35" Background="#71006510"/>
          </Canvas>
        </Grid>
        <TextBlock x:Name="PercentText" Margin="243,31,0,0" FontSize="11" FontFamily="Consolas" Foreground="White"/>
      </Grid>

      <ItemsControl x:Name="ResetItems" Grid.Row="2" Margin="0,8,0,8">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <StackPanel Orientation="Horizontal" Height="18">
              <Ellipse Width="7" Height="7" Fill="{Binding Brush}" Margin="0,0,12,0" VerticalAlignment="Center"/>
              <TextBlock Text="{Binding Text}" FontSize="10" FontFamily="Consolas" Foreground="{Binding Foreground}" VerticalAlignment="Center"/>
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <Grid Grid.Row="3" Width="272" HorizontalAlignment="Left">
        <Grid.ColumnDefinitions><ColumnDefinition Width="131"/><ColumnDefinition Width="10"/><ColumnDefinition Width="131"/></Grid.ColumnDefinitions>
        <Border x:Name="BalanceCard" Grid.Column="0" MinHeight="59" CornerRadius="9" Background="#4A737B7E" BorderBrush="#30FFFFFF" BorderThickness="1" Padding="4,7,4,5">
          <Grid><Grid.RowDefinitions><RowDefinition/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <TextBlock x:Name="BalanceTitle" Foreground="#B8C2C7" FontSize="9" FontFamily="Consolas" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Top"/>
            <TextBlock x:Name="BalanceValue" Grid.Row="1" Foreground="White" FontSize="13" FontFamily="Consolas" FontWeight="SemiBold" TextAlignment="Center" Margin="0,3,0,0"/>
          </Grid>
        </Border>
        <Border x:Name="ResetCard" Grid.Column="2" MinHeight="59" CornerRadius="9" Background="#4A737B7E" BorderBrush="#30FFFFFF" BorderThickness="1" Padding="4,7,4,5">
          <Grid><Grid.RowDefinitions><RowDefinition/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <TextBlock x:Name="ResetTitle" Foreground="#B8C2C7" FontSize="9" FontFamily="Consolas" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Top"/>
            <TextBlock x:Name="ResetValue" Grid.Row="1" Foreground="White" FontSize="13" FontFamily="Consolas" FontWeight="SemiBold" TextAlignment="Center" Margin="0,3,0,0"/>
          </Grid>
        </Border>
      </Grid>

      <StackPanel Grid.Row="4" Margin="0,5,0,0">
        <StackPanel Orientation="Horizontal" Height="17"><TextBlock Text="●" FontSize="9" Foreground="#AEB9BF" Width="20"/><TextBlock x:Name="AccountText" FontSize="10" FontFamily="Consolas" Foreground="#AEB9BF" TextTrimming="CharacterEllipsis" MaxWidth="270"/></StackPanel>
        <StackPanel Orientation="Horizontal" Height="17"><TextBlock Text="▣" FontSize="9" Foreground="#AEB9BF" Width="20"/><TextBlock x:Name="SubscriptionText" FontSize="10" FontFamily="Consolas" Foreground="#AEB9BF" TextTrimming="CharacterEllipsis" MaxWidth="270"/></StackPanel>
      </StackPanel>

      <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
        <Ellipse x:Name="UpdateDot" Width="4" Height="4" Fill="#FF3333" Margin="0,0,4,2" Visibility="Collapsed"/>
        <TextBlock x:Name="VersionText" FontSize="9" FontWeight="Light" FontFamily="Consolas" Foreground="#AEB9BF"/>
      </StackPanel>
    </Grid>
  </Border>
</Window>
